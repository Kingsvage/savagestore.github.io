rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Create an /admins/{uid} document manually in the Firebase console for each admin.
    // Example: /admins/YOUR_ADMIN_FIREBASE_UID with any field, such as email.
    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if false;
    }

    match /users/{userId} {
      allow create, update: if isOwner(userId) &&
        request.resource.data.uid == request.auth.uid;
      allow read: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'processing' &&
        request.resource.data.price is number &&
        request.resource.data.price > 0;

      allow read: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);

      allow update: if isAdmin() &&
        request.resource.data.status in ['processing', 'delivered', 'failed'];

      allow delete: if isAdmin();
    }

    match /listings/{listingId} {
      allow create: if signedIn() &&
        request.resource.data.sellerId == request.auth.uid &&
        request.resource.data.status == 'pending-review' &&
        request.resource.data.price is number &&
        request.resource.data.price > 0;

      // Allow signed-in users to read ALL listings (both pending and approved)
      allow read: if signedIn();

      // Allow reading approved listings for marketplace display
      allow list: if signedIn();

      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
